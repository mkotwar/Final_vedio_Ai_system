# App Settings
APP_NAME="AI Video Search Engine"
ENV="development"
DEBUG=true
HOST="127.0.0.1"
PORT=8000

# Logging Settings
# LOG_LEVEL can be DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
# LOG_FORMAT can be "text" or "json"
LOG_FORMAT="text"

# Storage Settings (Paths can be relative or absolute)
# Defaults are set relative to the root project directory
DATA_DIR="data"
VIDEOS_DIR="data/videos"
FRAMES_DIR="data/frames"
METADATA_DIR="data/metadata"
LOGS_DIR="data/logs"

# VLM Model Settings
VLM_ENGINE_TYPE="native_hf"
QWEN_MODEL_ID="Qwen/Qwen2.5-VL-7B-Instruct"
# MOCK_MODEL=true skips downloading the 15GB model for faster testing
MOCK_MODEL=true
BATCH_SIZE=4
QWEN_MAX_NEW_TOKENS=256

# Adaptive Sampling Settings
ENABLE_ADAPTIVE_SAMPLING=true
SSIM_THRESHOLD=0.92
HISTOGRAM_THRESHOLD=0.25
MOTION_THRESHOLD=0.15

# Qdrant & Embeddings Settings
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_COLLECTION="video_events"
EMBEDDING_MODEL_ID="BAAI/bge-m3"
USE_LOCAL_QDRANT=true
